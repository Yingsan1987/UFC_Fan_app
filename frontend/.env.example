# Frontend environment variables (copy to .env and fill in).

# Google Analytics 4 Measurement ID — get it from https://analytics.google.com
# (Admin → Data streams → your web stream → "G-XXXXXXXXXX").
# The app already ships with the production ID baked in (G-RV2N7CG2GF).
# Only set this to OVERRIDE it (e.g. a separate staging/dev property).
VITE_GA_MEASUREMENT_ID=
